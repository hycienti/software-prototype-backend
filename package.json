{
  "name": "havens-backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "start": "node bin/server.js",
    "build": "node ace build",
    "dev": "node ace serve --watch",
    "test": "node ace test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "docker:migrate": "docker-compose -f docker-compose.dev.yml exec api node ace migration:run",
    "docker:down": "docker-compose -f docker-compose.dev.yml down",
    "docker:build:clear": "docker-compose -f docker-compose.dev.yml build --no-cache",
    "docker:up:detached": "docker-compose -f docker-compose.dev.yml up -d",
    "docker:up": " docker-compose -f docker-compose.dev.yml up -d"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#models/*": "./app/models/*.js",
    "#mails/*": "./app/mails/*.js",
    "#services/*": "./app/services/*.js",
    "#listeners/*": "./app/listeners/*.js",
    "#events/*": "./app/events/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#validators/*": "./app/validators/*.js",
    "#providers/*": "./providers/*.js",
    "#policies/*": "./app/policies/*.js",
    "#abilities/*": "./app/abilities/*.js",
    "#database/*": "./database/*.js",
    "#start/*": "./start/*.js",
    "#tests/*": "./tests/*.js",
    "#config/*": "./config/*.js",
    "#enums/*": "./app/enums/*.js"
  },
  "devDependencies": {
    "@adonisjs/assembler": "latest",
    "@adonisjs/eslint-config": "latest",
    "@adonisjs/prettier-config": "^1.4.4",
    "@adonisjs/tsconfig": "^1.4.0",
    "@japa/assert": "^4.0.1",
    "@japa/plugin-adonisjs": "^4.0.0",
    "@japa/runner": "^4.2.0",
    "@swc/core": "1.11.24",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.15.18",
    "eslint": "^9.26.0",
    "hot-hook": "^0.4.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.5.3",
    "ts-node-maintained": "^10.9.5",
    "typescript": "~5.8"
  },
  "dependencies": {
    "@adonisjs/ally": "^5.1.1",
    "@adonisjs/auth": "^9.5.1",
    "@adonisjs/core": "^6.18.0",
    "@adonisjs/drive": "^3.4.1",
    "@adonisjs/lucid": "^21.8.2",
    "@aws-sdk/client-s3": "^3.975.0",
    "@aws-sdk/s3-request-presigner": "^3.975.0",
    "@elevenlabs/elevenlabs-js": "^2.32.0",
    "@google-cloud/storage": "^7.18.0",
    "@vinejs/vine": "^4.2.0",
    "adonis-autoswagger": "^3.73.0",
    "jose": "^6.1.3",
    "luxon": "^3.7.2",
    "openai": "^6.16.0",
    "pg": "^8.17.1",
    "pusher": "^5.3.2",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.8.0"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  },
  "eslintConfig": {
    "extends": "@adonisjs/eslint-config/app"
  },
  "prettier": "@adonisjs/prettier-config"
}
